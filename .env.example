# ─────────────────────────────────────────────────────────────────────────────
# URLs облачных backend-функций
# Скопируйте этот файл в .env и заполните значения
# ─────────────────────────────────────────────────────────────────────────────

# Организационные домены
VITE_ORG_DOMAINS_URL=https://functions.example.com/org-domains

# Технические домены
VITE_TECH_DOMAINS_URL=https://functions.example.com/tech-domains

# Технологии
VITE_TECHNOLOGIES_URL=https://functions.example.com/technologies

# Требования
VITE_REQUIREMENTS_URL=https://functions.example.com/requirements

# Решения (ТОС)
VITE_DECISIONS_URL=https://functions.example.com/decisions

# Харденинг
VITE_HARDENING_URL=https://functions.example.com/hardening

# Шаблоны архитектур
VITE_ARCH_TEMPLATES_URL=https://functions.example.com/arch-templates
