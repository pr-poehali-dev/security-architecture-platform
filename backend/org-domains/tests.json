{
  "tests": [
    {
      "name": "GET list (empty)",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": [],
      "bodyMatcher": "exact"
    },
    {
      "name": "POST create domain",
      "method": "POST",
      "path": "/",
      "body": "{\"name\": \"Тестовый домен\", \"owner\": \"Admin\", \"status\": \"active\", \"description\": \"Тест\"}",
      "expectedStatus": 201,
      "expectedBody": {"name": "Тестовый домен", "version": "1.0"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET list after create",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    }
  ]
}
